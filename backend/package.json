{
  "name": "vs-mes-backend",
  "version": "1.0.0",
  "description": "VS MES Backend - Express API for Dynamic Production Tracker",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "build": "node -e \"console.log('Backend build step: not required')\"",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "test": "node --test tests/**/*.test.js",
    "test:smoke": "npm test",
    "db:migrate": "psql $DATABASE_URL -f database/schema.sql",
    "db:migrate:all": "./scripts/migrate-all.sh",
    "bootstrap:superadmin": "node src/scripts/bootstrapSuperAdmin.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "globals": "^17.4.0",
    "nodemon": "^3.1.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
