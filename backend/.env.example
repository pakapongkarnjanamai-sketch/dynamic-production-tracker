# Server
PORT=4000
NODE_ENV=production

# PostgreSQL connection (required)
DATABASE_URL=postgresql://postgres:password@localhost:5432/lite_mes

# CORS allowlist (required) — comma-separated list of allowed origins
ALLOWED_ORIGINS=https://bpsgroup.cloud,https://www.bpsgroup.cloud

# JWT auth (required in all environments)
# IMPORTANT: replace with a long random secret in production.
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=12h

# SuperAdmin bootstrap
SUPERADMIN_EMPLOYEE_ID=ADMIN-0001
SUPERADMIN_NAME=Administrator
SUPERADMIN_PASSWORD=change-me-now
